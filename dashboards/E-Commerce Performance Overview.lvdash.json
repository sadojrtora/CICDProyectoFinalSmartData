{
  "datasets": [
    {
      "name": "34083425",
      "displayName": "agg_sales_summary (Revenue by country)",
      "queryLines": [
        "SELECT shipping_country, SUM(gross_revenue) AS total_revenue\r\n",
        "FROM catalog_ecommerce.golden.agg_sales_summary\r\n",
        "GROUP BY shipping_country\r\n",
        "ORDER BY total_revenue DESC\r\n",
        "LIMIT 10;"
      ],
      "catalog": "catalog_ecommerce",
      "schema": "golden"
    },
    {
      "name": "4ffe9ac8",
      "displayName": "agg_customer_360",
      "queryLines": [
        "select * from catalog_ecommerce.golden.agg_customer_360 limit 1000"
      ]
    },
    {
      "name": "9d4483ef",
      "displayName": "agg_product_performance",
      "queryLines": [
        "SELECT * FROM catalog_ecommerce.golden.agg_product_performance limit 1000"
      ],
      "columns": [
        {
          "displayName": "Estimated Sales",
          "description": "Estimated total sales calculated as price multiplied by review count as a proxy for sales volume",
          "expression": "`price` * `review_count`"
        },
        {
          "displayName": "Sales Performance Flag",
          "description": "Flag to identify products with high sales but low ratings for highlighting",
          "expression": "CASE \r\nWHEN (`price` * `review_count` > 60000) AND (`avg_rating` < 3.3) THEN 'High Sales, Low Rating' \r\nWHEN (`price` * `review_count` > 60000) THEN 'High Sales' \r\nWHEN (`avg_rating` < 3.3) THEN 'Low Rating' ELSE 'Normal' END"
        }
      ]
    },
    {
      "name": "536ada82",
      "displayName": "Review Sentiment Analysis",
      "queryLines": [
        "SELECT\n",
        "  'Positive' as sentiment_type,\n",
        "  category,\n",
        "  SUM(positive_count) as review_count\n",
        "FROM\n",
        "  catalog_ecommerce.golden.agg_review_sentiment\n",
        "GROUP BY\n",
        "  category\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Neutral' as sentiment_type,\n",
        "  category,\n",
        "  SUM(neutral_count) as review_count\n",
        "FROM\n",
        "  catalog_ecommerce.golden.agg_review_sentiment\n",
        "GROUP BY\n",
        "  category\n",
        "UNION ALL\n",
        "SELECT\n",
        "  'Negative' as sentiment_type,\n",
        "  category,\n",
        "  SUM(negative_count) as review_count\n",
        "FROM\n",
        "  catalog_ecommerce.golden.agg_review_sentiment\n",
        "GROUP BY\n",
        "  category"
      ]
    },
    {
      "name": "6f5ded47",
      "displayName": "agg_sales_summary (Order value over time)",
      "queryLines": [
        "SELECT order_date_dt, SUM(avg_order_value) as total_order_value\r\n",
        "FROM catalog_ecommerce.golden.agg_sales_summary\r\n",
        "GROUP BY order_date_dt\r\n",
        "ORDER BY order_date_dt ASC;"
      ],
      "catalog": "catalog_ecommerce",
      "schema": "golden"
    }
  ],
